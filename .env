# Runtime Grafana version for `npm run server` (docker compose).
# Pinned to 13.1.0 to match the plugin's @grafana/* dev dependencies: the React
# VizTooltip tooltip uses the VizTooltipWrapper/Content/Header/Footer API (data
# links + ad-hoc filters), which is only in the @grafana/ui runtime from 13.1.0.
# The base compose reads ${GRAFANA_VERSION:-13.0.2}; this overrides that default.
GRAFANA_VERSION=13.1.0
